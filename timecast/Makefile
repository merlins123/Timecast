APPLICATION = timecast

RIOTBASE ?= $(CURDIR)/../..
NODE_ID ?= 0
TIMECAST_LOCAL_HOP ?= $(NODE_ID)
TIMECAST_NTX ?= 8
TIMECAST_AA ?= 0xA7B3C5D9
TIMECAST_USE_PRE_P2 ?= 1
TIMECAST_APP_DATA_LEN ?= 0
TIMECAST_LOG_RX_EACH ?= 0
TIMECAST_TX_MIN_ARM_LEAD_US ?= 8
TIMECAST_ERR_LOG_EVERY ?= 256
TIMECAST_FAST_RAMPUP ?= 1
TIMECAST_P1_SLOT_US ?=
TIMECAST_P2_SUBSLOT_US ?=
TIMECAST_ROUND_GAP_US ?=
TIMECAST_SLOT_PROCESSING_US ?= 40
TIMECAST_PRE_P2_SLOT_PROCESSING_US ?= 35
TIMECAST_RADIO_RAMPUP_US ?= 40
TIMECAST_P2_NODE_COUNT ?= 4
TIMECAST_STORE_MAX_NODES ?= $(TIMECAST_P2_NODE_COUNT)
TIMECAST_VIRTUAL_SOURCE_MOD ?= 4
TIMECAST_P2_START_GUARD_US ?=
TIMECAST_PRE_P2_SUBSLOT_GUARD_US ?= 10
TIMECAST_P2_SUBSLOT_GUARD_US ?= 40
TIMECAST_P2_RX_WINDOW_US ?=
TIMECAST_SLOT_PHY_OVERHEAD_BYTES ?= 16

CFLAGS += -I$(CURDIR)/include
CFLAGS += -DNODE_ID=$(NODE_ID)
CFLAGS += -DTCAST_USE_PRE_P2=$(TIMECAST_USE_PRE_P2)
CFLAGS += -DTCAST_LOCAL_HOP=$(TIMECAST_LOCAL_HOP)
CFLAGS += -DTCAST_NTX=$(TIMECAST_NTX)
CFLAGS += -DTCAST_APP_DATA_LEN=$(TIMECAST_APP_DATA_LEN)
CFLAGS += -DTCAST_VIRTUAL_SOURCE_MOD=$(TIMECAST_VIRTUAL_SOURCE_MOD)
CFLAGS += -DTCAST_ACCESS_ADDRESS=$(TIMECAST_AA)
CFLAGS += -DTCAST_LOG_RX_EACH=$(TIMECAST_LOG_RX_EACH)
CFLAGS += -DTCAST_TX_MIN_ARM_LEAD_US=$(TIMECAST_TX_MIN_ARM_LEAD_US)
CFLAGS += -DTCAST_ERR_LOG_EVERY=$(TIMECAST_ERR_LOG_EVERY)
CFLAGS += -DTCAST_FAST_RAMPUP=$(TIMECAST_FAST_RAMPUP)
CFLAGS += -DTCAST_SLOT_PROCESSING_US=$(TIMECAST_SLOT_PROCESSING_US)
CFLAGS += -DTCAST_PRE_P2_SLOT_PROCESSING_US=$(TIMECAST_PRE_P2_SLOT_PROCESSING_US)
CFLAGS += -DTCAST_RADIO_RAMPUP_US=$(TIMECAST_RADIO_RAMPUP_US)
CFLAGS += -DTIMECAST_STORE_MAX_NODES=$(TIMECAST_STORE_MAX_NODES)
CFLAGS += -DTCAST_P2_NODE_COUNT=$(TIMECAST_P2_NODE_COUNT)
CFLAGS += -DTCAST_PRE_P2_SUBSLOT_GUARD_US=$(TIMECAST_PRE_P2_SUBSLOT_GUARD_US)
CFLAGS += -DTCAST_P2_SUBSLOT_GUARD_US=$(TIMECAST_P2_SUBSLOT_GUARD_US)
CFLAGS += -DTCAST_SLOT_PHY_OVERHEAD_BYTES=$(TIMECAST_SLOT_PHY_OVERHEAD_BYTES)
ifneq ($(strip $(TIMECAST_P1_SLOT_US)),)
CFLAGS += -DTCAST_P1_SLOT_US=$(TIMECAST_P1_SLOT_US)
endif
ifneq ($(strip $(TIMECAST_P2_SUBSLOT_US)),)
CFLAGS += -DTCAST_P2_SUBSLOT_US=$(TIMECAST_P2_SUBSLOT_US)
endif
ifneq ($(strip $(TIMECAST_P2_START_GUARD_US)),)
CFLAGS += -DTCAST_P2_START_GUARD_US=$(TIMECAST_P2_START_GUARD_US)
endif
ifneq ($(strip $(TIMECAST_P2_RX_WINDOW_US)),)
CFLAGS += -DTCAST_P2_RX_WINDOW_US=$(TIMECAST_P2_RX_WINDOW_US)
endif
ifneq ($(strip $(TIMECAST_ROUND_GAP_US)),)
CFLAGS += -DTCAST_ROUND_GAP_US=$(TIMECAST_ROUND_GAP_US)
endif

include $(RIOTBASE)/Makefile.include
