APPLICATION = timecast


BOARD ?= feather-nrf52840-sense

RIOTBASE ?= $(CURDIR)/../..

USEMODULE += nrf_sf_radio


NODE_ID ?= 0
TIMECAST_SLOT_PROCESSING_US ?= 88
TIMECAST_PRE_P2_SLOT_PROCESSING_US ?= 40
TIMECAST_FAST_RAMPUP ?= 1
ifeq ($(TIMECAST_FAST_RAMPUP),1)
TIMECAST_RADIO_RAMPUP_US ?= 40
else
TIMECAST_RADIO_RAMPUP_US ?= 140
endif
TIMECAST_SLOT_PHY_OVERHEAD_BYTES ?= 8
TIMECAST_LOCAL_PAYLOAD_META_LEN ?= 6
TIMECAST_NTX ?= 10
TIMECAST_USE_PRE_P2 ?= 1
TIMECAST_APP_DATA_LEN ?= 0
TIMECAST_TEST_NODE2_CLASS_PERIOD ?= 0
TIMECAST_TEST_NODE2_CLASS_MIN ?= 1
TIMECAST_TEST_NODE2_CLASS_MAX ?= 15
TIMECAST_TX_MIN_ARM_LEAD_US ?= 8
TIMECAST_ERR_LOG_EVERY ?= 256
TIMECAST_P1_SLOT_US ?= \(SLOT_PROCESSING_US+RADIO_RAMPUP_US+PACKET_AIR_TIME_US\(PACKET_P1_SYNC_PAYLOAD_LEN\)\)
TIMECAST_P2_SUBSLOT_US ?= P2_PAYLOAD_TO_SUBSLOT_US\(LOCAL_P2_PAYLOAD_LEN\)
TIMECAST_PRE_P2_SUBSLOT_US ?= \(PRE_P2_SLOT_PROCESSING_US+RADIO_RAMPUP_US+PACKET_AIR_TIME_US\(PACKET_PRE_P2_CTRL_LEN\)\)
TIMECAST_MASTER_START_DELAY_US ?= \(4U*P1_SLOT_US\)
TIMECAST_ROUND_GAP_US ?= \(200U*P1_SLOT_US\)
TIMECAST_P2_NODE_COUNT ?= 4
TIMECAST_STORE_MAX_NODES ?= $(TIMECAST_P2_NODE_COUNT)
TIMECAST_P2_START_GUARD_US ?= P1_SLOT_US
TIMECAST_PRE_P2_SUBSLOT_GUARD_US ?= 10
TIMECAST_P2_SUBSLOT_GUARD_US ?= 40
TIMECAST_P2_RX_WINDOW_US ?= \(RADIO_RAMPUP_US+50U\)
TIMECAST_P2_RX_WINDOW_MARGIN_US ?= 24
TIMECAST_P1_RX_TS_TO_SLOT_START_US ?= 40
TIMECAST_P2_RX_LEAD_US ?= 40
TIMECAST_P1_SCAN_LOG_INTERVAL_US ?= 1000000
TIMECAST_MASTER_P2_INCOMPLETE_PRE_THRESHOLD ?= 10

CFLAGS += -I$(CURDIR)/include
CFLAGS += -DNODE_ID=$(NODE_ID)
CFLAGS += -DLOCAL_NODE_ID=$(NODE_ID)
CFLAGS += -DSLOT_PROCESSING_US=$(TIMECAST_SLOT_PROCESSING_US)
CFLAGS += -DPRE_P2_SLOT_PROCESSING_US=$(TIMECAST_PRE_P2_SLOT_PROCESSING_US)
CFLAGS += -DNRF_SF_RADIO_FAST_RAMPUP=$(TIMECAST_FAST_RAMPUP)
CFLAGS += -DRADIO_RAMPUP_US=$(TIMECAST_RADIO_RAMPUP_US)
CFLAGS += -DSLOT_PHY_OVERHEAD_BYTES=$(TIMECAST_SLOT_PHY_OVERHEAD_BYTES)
CFLAGS += -DLOCAL_PAYLOAD_META_LEN=$(TIMECAST_LOCAL_PAYLOAD_META_LEN)
CFLAGS += -DUSE_PRE_P2=$(TIMECAST_USE_PRE_P2)
CFLAGS += -DNTX=$(TIMECAST_NTX)
CFLAGS += -DAPP_DATA_LEN=$(TIMECAST_APP_DATA_LEN)
CFLAGS += -DTEST_NODE2_CLASS_PERIOD=$(TIMECAST_TEST_NODE2_CLASS_PERIOD)
CFLAGS += -DTEST_NODE2_CLASS_MIN=$(TIMECAST_TEST_NODE2_CLASS_MIN)
CFLAGS += -DTEST_NODE2_CLASS_MAX=$(TIMECAST_TEST_NODE2_CLASS_MAX)
CFLAGS += -DTX_MIN_ARM_LEAD_US=$(TIMECAST_TX_MIN_ARM_LEAD_US)
CFLAGS += -DERR_LOG_EVERY=$(TIMECAST_ERR_LOG_EVERY)
CFLAGS += -DTIMECAST_STORE_MAX_NODES=$(TIMECAST_STORE_MAX_NODES)
CFLAGS += -DP2_NODE_COUNT=$(TIMECAST_P2_NODE_COUNT)
CFLAGS += -DP1_SLOT_US=$(TIMECAST_P1_SLOT_US)
CFLAGS += -DP2_SUBSLOT_US=$(TIMECAST_P2_SUBSLOT_US)
CFLAGS += -DPRE_P2_SUBSLOT_US=$(TIMECAST_PRE_P2_SUBSLOT_US)
CFLAGS += -DMASTER_START_DELAY_US=$(TIMECAST_MASTER_START_DELAY_US)
CFLAGS += -DROUND_GAP_US=$(TIMECAST_ROUND_GAP_US)
CFLAGS += -DP2_START_GUARD_US=$(TIMECAST_P2_START_GUARD_US)
CFLAGS += -DPRE_P2_SUBSLOT_GUARD_US=$(TIMECAST_PRE_P2_SUBSLOT_GUARD_US)
CFLAGS += -DP2_SUBSLOT_GUARD_US=$(TIMECAST_P2_SUBSLOT_GUARD_US)
CFLAGS += -DP2_RX_WINDOW_US=$(TIMECAST_P2_RX_WINDOW_US)
CFLAGS += -DP2_RX_WINDOW_MARGIN_US=$(TIMECAST_P2_RX_WINDOW_MARGIN_US)
CFLAGS += -DP1_RX_TS_TO_SLOT_START_US=$(TIMECAST_P1_RX_TS_TO_SLOT_START_US)
CFLAGS += -DP2_RX_LEAD_US=$(TIMECAST_P2_RX_LEAD_US)
CFLAGS += -DP1_SCAN_LOG_INTERVAL_US=$(TIMECAST_P1_SCAN_LOG_INTERVAL_US)
CFLAGS += -DMASTER_P2_INCOMPLETE_PRE_THRESHOLD=$(TIMECAST_MASTER_P2_INCOMPLETE_PRE_THRESHOLD)

include $(RIOTBASE)/Makefile.include
